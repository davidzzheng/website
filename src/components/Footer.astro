---

<footer class="border-t border-terminal-border py-6 mt-20">
  <div class="flex items-center justify-between text-xs text-terminal-dim">
    <p>David Zheng</p>
    <div
      class="flex items-center gap-0.5 rounded border border-terminal-border bg-white/[0.02] p-0.5"
      id="theme-switch"
      role="radiogroup"
      aria-label="Theme"
    >
      <button type="button" data-theme="light" class="theme-btn flex size-5 items-center justify-center rounded text-terminal-dim transition-colors" aria-label="Light">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M6.3 17.7l-1.4 1.4M19.1 4.9l-1.4 1.4"/></svg>
      </button>
      <button type="button" data-theme="dark" class="theme-btn flex size-5 items-center justify-center rounded text-terminal-dim transition-colors" aria-label="Dark">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
      </button>
    </div>
  </div>
</footer>

<script>
  const applyTheme = (theme: string) => {
    const isDark = theme === "dark" || (theme === "system" && matchMedia("(prefers-color-scheme: dark)").matches);
    document.documentElement.classList.toggle("dark", isDark);
    localStorage.setItem("theme", theme);
  };
  const syncButtons = () => {
    const cur = localStorage.getItem("theme") || "dark";
    const buttons = document.querySelectorAll<HTMLButtonElement>(".theme-btn");
    for (const b of buttons) {
      const a = b.dataset.theme === cur;
      b.classList.toggle("text-accent", a);
      b.classList.toggle("bg-accent/10", a);
    }
  };
  const themeButtons = document.querySelectorAll<HTMLButtonElement>(".theme-btn");
  for (const b of themeButtons) {
    b.addEventListener("click", () => {
      const t = b.dataset.theme;
      if (t) {
        applyTheme(t);
        syncButtons();
      }
    });
  }
  syncButtons();
</script>
