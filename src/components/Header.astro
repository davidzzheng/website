---
const links = [
  { href: "/work", label: "work", pattern: /^\/work/u },
  { href: "/posts", label: "writing", pattern: /^\/posts/u },
  { href: "/contact", label: "contact", pattern: /^\/contact/u },
];
const {pathname} = Astro.url;
---

<header class="flex items-center justify-between py-6 text-sm">
  <a href="/" class="link text-terminal-text">
    <span class="text-accent">~/</span>dz
  </a>
  <nav class="flex items-center gap-5">
    {links.map(({ label, href, pattern }) => {
      const isActive = pattern.test(pathname);
      return (
        <a
          href={href}
          class:list={["link", isActive ? "active text-accent" : "text-terminal-dim"]}
        >
          {label}
        </a>
      );
    })}
  </nav>
</header>
