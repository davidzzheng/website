---
import { getPositions, getProjects } from "@/lib/content";
import BaseLayout from "@/layouts/BaseLayout.astro";

const positions = await getPositions();
const projects = await getProjects();
---

<BaseLayout title="work">
  <section class="section" data-section="work">
    <div class="section-header">
      <span class="section-num">01</span>
      <span class="section-label">experience</span>
      <span class="section-line"></span>
    </div>

    <h1 class="page-title">where i've worked</h1>
    <p class="page-intro">{positions.length} roles across startups and enterprise. mostly building things that ship.</p>
    <div class="work-list">
      {positions.map((pos) => {
        const startYear = new Date(pos.data.start).getFullYear();
        const endYear = pos.data.end ? new Date(pos.data.end).getFullYear() : null;
        return (
          <a href={`/work/${pos.id}`} class="work-row entry">
            <span class="work-year">{startYear}{endYear && endYear !== startYear ? `—${endYear}` : ""}</span>
            <div class="work-info">
              <h3 class="work-company">{pos.data.company}</h3>
              <span class="work-role">{pos.data.title}</span>
            </div>
            <span class="work-arrow">→</span>
          </a>
        );
      })}
    </div>

    <div class="proj-section">
      <div class="sub-label">projects</div>
      <div class="work-list">
        {projects.map((proj) => {
          return (
            <a href={`/projects/${proj.id}`} class="work-row entry">
              <span class="work-year">{proj.data.year}</span>
              <div class="work-info">
                <h3 class="work-company">{proj.data.title}</h3>
                <span class="work-role">{proj.data.description}</span>
              </div>
              <span class="work-arrow">→</span>
            </a>
          );
        })}
      </div>
    </div>
  </section>
</BaseLayout>
