---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getAllTags } from "@/lib/posts";

const tags = await getAllTags();
---

<BaseLayout title="tags">
  <section class="section" data-section="writing">
    <div class="section-header">
      <span class="section-num">02</span>
      <span class="section-label">tags</span>
      <span class="section-line"></span>
    </div>

    <div class="tag-list">
      {tags.map(({ tag, count }) => (
        <a href={`/tags/${tag}`} class="tag-item">
          <span class="tag-name">#{tag}</span>
          <span class="tag-count">{count}</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .tag-list { max-width: 820px; }
  .tag-item {
    display: flex; align-items: center; justify-content: space-between;
    padding: 20px 0; border-bottom: 1px solid var(--color-border);
    text-decoration: none; transition: padding-left 250ms cubic-bezier(0.2,0.8,0.2,1);
  }
  .tag-item:hover { padding-left: 16px; }
  .tag-name {
    font-family: var(--font-sans); font-size: clamp(1.25rem, 3vw, 1.75rem);
    font-weight: 700; letter-spacing: -0.02em; color: var(--color-text);
    transition: color 150ms;
  }
  .tag-item:hover .tag-name { color: var(--color-accent); }
  .tag-count {
    font-family: var(--font-mono); font-size: 13px;
    color: var(--color-text-faint);
  }
</style>
