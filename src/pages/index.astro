---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getLatestPosts, getPositions } from "@/lib/content";
import { format } from "date-fns";
import { EMAIL, GITHUB, LINKEDIN } from "@/lib/constants";

const latestPosts = await getLatestPosts(3);
const workPositions = await getPositions("work");
const communityPositions = await getPositions("community");

type TimelineItem = {
  name: string;
  role: string;
  sortYear: number;
  dateLabel: string;
  isCurrent: boolean;
  isExternal: boolean;
  link?: string;
  kind: "work" | "community";
};

const timeline: TimelineItem[] = [
  ...workPositions.map((p) => {
    const start = new Date(p.data.start).getFullYear();
    const end = p.data.end ? new Date(p.data.end).getFullYear() : null;
    return {
      name: p.data.company,
      role: p.data.title,
      sortYear: start,
      dateLabel: `${start}${end ? `—${end}` : "—present"}`,
      isCurrent: !p.data.end,
      isExternal: p.data.link && p.data.link !== "#",
      link: p.data.link !== "#" ? p.data.link : undefined,
      kind: "work" as const,
    };
  }),
  ...communityPositions.map((p) => {
    const start = new Date(p.data.start).getFullYear();
    const end = p.data.end ? new Date(p.data.end).getFullYear() : null;
    return {
      name: p.data.company,
      role: p.data.title,
      sortYear: start,
      dateLabel: `${start}${end ? `—${end}` : "—present"}`,
      isCurrent: !p.data.end,
      isExternal: p.data.link && p.data.link !== "#",
      link: p.data.link !== "#" ? p.data.link : undefined,
      kind: "community" as const,
    };
  }),
].sort((a, b) => b.sortYear - a.sortYear);
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "David Zheng",
  url: "https://davidzheng.me",
  jobTitle: "Fullstack Developer",
  email: `mailto:${EMAIL}`,
  sameAs: [GITHUB, LINKEDIN],
};
---

<BaseLayout jsonLd={jsonLd}>

  {/* ═══════════════════════════════════════════
      HERO — bold, asymmetric, massive type
      ═══════════════════════════════════════════ */}
  <section class="section" data-section="home" id="hero">
    <div class="hero-content">
      <h1 id="hero-name" class="hero-name" data-text="DAVID ZHENG">
        DAVID ZHENG
      </h1>
      <div class="hero-sub">
        <span class="hero-tag">software engineer · vancouver</span>
        <div class="hero-links">
          <a href={GITHUB} target="_blank" rel="noopener noreferrer">github ↗</a>
          <a href={`mailto:${EMAIL}`}>email ↗</a>
          <a href={LINKEDIN} target="_blank" rel="noopener noreferrer">linkedin ↗</a>
        </div>
      </div>
    </div>
  </section>

  {/* ═══════════════════════════════════════════
      WORK — unified timeline
      ═══════════════════════════════════════════ */}
  <section class="section" data-section="work">
    <div class="section-header">
      <span class="section-num">01</span>
      <span class="section-label">work</span>
      <span class="section-line"></span>
    </div>

    <div class="tl">
      {timeline.map((item) => (
        <a
          {...(item.isExternal && item.link ? { href: item.link, target: "_blank", rel: "noopener noreferrer" } : {})}
          class={`tl-row entry ${item.isCurrent ? "tl-current" : ""} tl-${item.kind}`}
          data-company={item.name}
        >
          <span class={`tl-dot ${item.isCurrent ? "tl-dot-on" : ""} tl-dot-${item.kind}`}></span>
          <div class="tl-body">
            <span class="tl-company">{item.name}</span>
            <span class="tl-role">{item.role}</span>
          </div>
          <span class="tl-date">{item.dateLabel}</span>
          {item.isExternal && <span class="tl-arrow">↗</span>}
        </a>
      ))}
    </div>

    <a href="/work" class="work-more link-hover">full history →</a>
  </section>

  {/* ═══════════════════════════════════════════
      WRITING — editorial post entries
      ═══════════════════════════════════════════ */}
  {latestPosts.length > 0 && (
    <section class="section" data-section="writing">
      <div class="section-header reveal">
        <span class="section-num">02</span>
        <span class="section-label">writing</span>
        <span class="section-line"></span>
      </div>

      <div class="write-list reveal-stagger">
        {latestPosts.map((post, i) => {
          const num = String(latestPosts.length - i).padStart(2, "0");
          const words = post.body?.trim().split(/\s+/).length ?? 0;
          const readTime = Math.max(1, Math.round(words / 200));
          return (
            <a href={`/posts/${post.id.replace(/\/index$/, "")}`} class="write-entry entry">
              <span class="write-num">{num}</span>
              <div class="write-body">
                <h3 class="write-title">{post.data.title}</h3>
                <p class="write-desc">{post.data.description}</p>
                {post.data.tags.length > 0 && (
                  <div class="write-tags">
                    {post.data.tags.map((tag) => (
                      <span class="write-tag">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
              <span class="write-date">
                {format(post.data.date, "MMM yyyy")} · {readTime}m
              </span>
            </a>
          );
        })}
      </div>

      <a href="/posts" class="work-more link-hover">all posts →</a>
    </section>
  )}

  {/* ═══════════════════════════════════════════
      CONTACT — bold, direct
      ═══════════════════════════════════════════ */}
  <section class="section" data-section="contact">
    <div class="section-header reveal">
      <span class="section-num">03</span>
      <span class="section-label">contact</span>
      <span class="section-line"></span>
    </div>

    <div class="contact-content reveal">
      <a href={`mailto:${EMAIL}`} class="contact-email group">
        <span class="contact-label">let's talk</span>
        <span class="contact-address">{EMAIL}</span>
      </a>

      <div class="contact-links">
        <a href={GITHUB} target="_blank" rel="noopener noreferrer" class="contact-link">
          <span class="contact-link-label">github</span>
          <span class="contact-link-handle">@davidzzheng ↗</span>
        </a>
        <a href={LINKEDIN} target="_blank" rel="noopener noreferrer" class="contact-link">
          <span class="contact-link-label">linkedin</span>
          <span class="contact-link-handle">/in/davidzzheng ↗</span>
        </a>
      </div>

      <div class="contact-footer">
        david zheng · vancouver · {new Date().getFullYear()}
      </div>
    </div>
  </section>

<script>
  let cleanup: (() => void) | undefined;
  let loaded = false;

  function startBackground() {
    if (window.location.pathname !== "/") {
      cleanup?.();
      cleanup = undefined;
      loaded = false;
      return;
    }

    cleanup?.();
    cleanup = undefined;
    loaded = false;

    // Mouse parallax — hero drifts opposite to particles (depth)
    const heroContent = document.getElementById("hero-content");
    if (heroContent) {
      document.addEventListener("mousemove", (e) => {
        const nx = e.clientX / window.innerWidth - 0.5;
        const ny = e.clientY / window.innerHeight - 0.5;
        heroContent.style.left = `${nx * -16}px`;
        heroContent.style.top = `${ny * -10}px`;
      }, { passive: true });
    }

    // Hover experience entries → morph particles into company name
    document.querySelectorAll<HTMLElement>("[data-section='work'] [data-company]").forEach((el) => {
      const company = el.dataset.company || "";
      el.addEventListener("mouseenter", () => {
        window.dispatchEvent(new CustomEvent("particle-hover", { detail: company }));
      });
      el.addEventListener("mouseleave", () => {
        window.dispatchEvent(new CustomEvent("particle-hover", { detail: null }));
      });
    });

    const canvas = document.getElementById("hero-canvas") as HTMLCanvasElement | null;
    if (!canvas) return;

    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduceMotion) return;

    const load = () => {
      if (loaded || !canvas) return;
      loaded = true;
      import("@/lib/phosphor").then(({ initFlowField }) => {
        cleanup = initFlowField(canvas) || undefined;
      });
    };

    if ("requestIdleCallback" in window) {
      (window as unknown as { requestIdleCallback: (cb: () => void) => void }).requestIdleCallback(load);
    } else {
      setTimeout(load, 200);
    }
  }
  document.addEventListener("astro:page-load", startBackground);
</script>
</BaseLayout>
